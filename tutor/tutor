#!/usr/bin/env node

const fs = require("node:fs/promises");
const path = require("node:path");
const { spawn, spawnSync } = require("node:child_process");
const { AutoComplete, Confirm, Input } = require("enquirer");
const { runTutorialApp } = require("./tutor-runtime");

const ROOT_DIR = __dirname;
const PROJECT_DIR = ROOT_DIR;
const TUTORIALS_DIR = path.join(ROOT_DIR, "tutorials");
const OUTLINE_INSTRUCTION_PATH = path.join(ROOT_DIR, "tutorial_outline_instruction.md");
const RESEARCH_INSTRUCTION_PATH = path.join(ROOT_DIR, "tutorial_research_instruction.md");
const TUTORIAL_ID_PATTERN = /^[a-z0-9][a-z0-9_-]*$/;
const TUTORIAL_OUTLINE_FILE = "tutorial-outline.json";
const TUTORIAL_JSON_FILE = "tutorial.json";
const TUTORIAL_HTML_FILE = "tutorial.html";
const AUDIT_DIR = ".logs";
const AUDIT_FILE_NAMES = {
  outline: "outline_audit.txt",
  research: "research_audit.txt",
};
const AUTHORING_MODEL = "openai/gpt-5.4";
const AUTHORING_AGENT = "build";
const CREATE_NEW_TUTORIAL = Symbol("create-new-tutorial");
const PROMPT_CANCELLED = Symbol("prompt-cancelled");

class TutorialAutocompletePrompt extends AutoComplete {
  constructor(options) {
    super(options);
    this.creatingNewTutorial = false;
  }

  format() {
    if (this.creatingNewTutorial) {
      return this.styles.primary("create new tutorial");
    }

    return super.format();
  }

  async newItem() {
    this.creatingNewTutorial = true;
    this.value = CREATE_NEW_TUTORIAL;
    this.state.submitted = true;
    await this.render();
    await this.close();
    this.emit("submit", this.value);
  }
}

async function main() {
  const args = process.argv.slice(2);
  const flags = new Set(args.filter((arg) => arg.startsWith("-")));
  const positionals = args.filter((arg) => !arg.startsWith("-"));

  if (flags.has("--help") || flags.has("-h")) {
    printUsage();
    return;
  }

  if (positionals[0] === "vibe") {
    if (positionals.length > 1) {
      throw new Error("Run `tutor vibe` with no additional positional arguments.");
    }

    await startVibeSession();
    return;
  }

  if (positionals.length > 0) {
    throw new Error("Run `tutor` with no positional arguments, or use `tutor vibe`.");
  }

  const selection = await promptForTutorialID();
  if (!selection) {
    return;
  }

  const tutorialDir = path.join(TUTORIALS_DIR, selection.id);
  if (selection.mode === "study") {
    await startStudySession({ tutorialDir, flags });
    return;
  }

  await startAuthoringSession(selection.id, tutorialDir, flags);
}

async function promptForTutorialID() {
  await fs.mkdir(TUTORIALS_DIR, { recursive: true });
  const tutorials = await listTutorials();
  const tutorialStatus = new Map([
    ...tutorials.ready.map((tutorialID) => [tutorialID, "ready"]),
    ...tutorials.draft.map((tutorialID) => [tutorialID, "draft"]),
  ]);
  const tutorialChoices = [
    ...tutorials.ready.map((tutorialID) => buildTutorialChoice(tutorialID, "ready")),
    ...tutorials.draft.map((tutorialID) => buildTutorialChoice(tutorialID, "draft")),
  ];

  const selection = await runPrompt(
    new TutorialAutocompletePrompt({
      name: "tutorialID",
      message: "Tutorial id",
      limit: 8,
      choices: tutorialChoices,
      footer() {
        if (tutorialChoices.length === 0) {
          return "No tutorials yet. Press Ctrl+N to create one.";
        }

        if (this.visible.length === 0) {
          return "No matches. Press Ctrl+N to create a new tutorial.";
        }

        return "Type to filter. Enter opens the selected tutorial. Ctrl+N creates a new tutorial.";
      },
      suggest(input, choices) {
        return suggestTutorialChoices(input, choices);
      },
    })
  );

  if (selection === PROMPT_CANCELLED) {
    return null;
  }

  if (selection === CREATE_NEW_TUTORIAL) {
    const tutorialID = await promptForNewTutorialID(tutorialStatus);
    return tutorialID ? { mode: "author", id: tutorialID } : null;
  }

  const selectionStatus = tutorialStatus.get(selection);
  if (selectionStatus === "ready") {
    return { mode: "study", id: selection };
  }

  if (selectionStatus === "draft") {
    const shouldContinue = await confirm(
      `Tutorial \"${selection}\" is a draft without a finished tutorial.json. Continue authoring it?`,
      true
    );
    return shouldContinue ? { mode: "author", id: selection } : null;
  }

  return null;
}

function buildTutorialChoice(tutorialID, status) {
  return {
    name: tutorialID,
    message: tutorialID,
    hint: status,
  };
}

async function promptForNewTutorialID(existingTutorials) {
  const tutorialID = await runPrompt(
    new Input({
      name: "tutorialID",
      message: "New tutorial id",
      hint: "Use lowercase letters, numbers, underscores, or hyphens.",
      validate(value) {
        const tutorialID = value.trim();

        if (!tutorialID) {
          return "Tutorial id is required.";
        }

        if (!TUTORIAL_ID_PATTERN.test(tutorialID)) {
          return "Tutorial IDs must use lowercase letters, numbers, underscores, or hyphens.";
        }

        if (existingTutorials.has(tutorialID)) {
          return `Tutorial \"${tutorialID}\" already exists.`;
        }

        return true;
      },
      result(value) {
        return value.trim();
      },
    })
  );

  if (tutorialID === PROMPT_CANCELLED) {
    return null;
  }

  return tutorialID;
}

async function confirm(message, defaultYes) {
  const answer = await runPrompt(
    new Confirm({
      name: "confirmed",
      message,
      initial: defaultYes,
    })
  );

  if (answer === PROMPT_CANCELLED) {
    return false;
  }

  return answer;
}

async function runPrompt(prompt) {
  return new Promise((resolve, reject) => {
    let settled = false;

    const complete = (handler, value) => {
      if (settled) {
        return;
      }

      settled = true;
      process.off("SIGINT", handleSigint);
      handler(value);
    };

    const handleSigint = async () => {
      try {
        await prompt.cancel();
      } catch {
        // Ignore prompt shutdown errors while exiting from Ctrl+C.
      }

      complete(resolve, PROMPT_CANCELLED);
    };

    process.on("SIGINT", handleSigint);
    prompt.run().then(
      (value) => complete(resolve, value),
      (error) => {
        if (error === "" || error == null) {
          complete(resolve, PROMPT_CANCELLED);
          return;
        }

        complete(reject, error);
      }
    );
  });
}

function suggestTutorialChoices(input, choices) {
  const query = normalizeTutorialQuery(input);
  if (!query.compact) {
    return choices;
  }

  return choices
    .map((choice) => ({
      choice,
      score: scoreTutorialMatch(query, choice.name),
    }))
    .filter((entry) => entry.score > Number.NEGATIVE_INFINITY)
    .sort((left, right) => right.score - left.score || left.choice.name.localeCompare(right.choice.name))
    .map((entry) => entry.choice);
}

function scoreTutorialMatch(query, tutorialID) {
  const rawCandidate = String(tutorialID || "").toLowerCase();
  const compactCandidate = rawCandidate.replace(/[-_]/g, "");

  if (query.raw === rawCandidate || query.compact === compactCandidate) {
    return 5000 - rawCandidate.length;
  }

  if (rawCandidate.startsWith(query.raw) || compactCandidate.startsWith(query.compact)) {
    return 4000 - rawCandidate.length;
  }

  const rawSubstringIndex = rawCandidate.indexOf(query.raw);
  if (rawSubstringIndex >= 0) {
    return 3000 - rawSubstringIndex * 10 - rawCandidate.length;
  }

  const compactSubstringIndex = compactCandidate.indexOf(query.compact);
  if (compactSubstringIndex >= 0) {
    return 2500 - compactSubstringIndex * 10 - compactCandidate.length;
  }

  const subsequenceScore = scoreSubsequenceMatch(query.compact, compactCandidate);
  return subsequenceScore === null ? Number.NEGATIVE_INFINITY : 1000 + subsequenceScore;
}

function scoreSubsequenceMatch(query, candidate) {
  let queryIndex = 0;
  let score = 0;
  let firstMatchIndex = -1;
  let previousMatchIndex = -2;

  for (let candidateIndex = 0; candidateIndex < candidate.length; candidateIndex += 1) {
    if (candidate[candidateIndex] !== query[queryIndex]) {
      continue;
    }

    if (firstMatchIndex === -1) {
      firstMatchIndex = candidateIndex;
      score += Math.max(0, 15 - candidateIndex);
    }

    score += 5;
    if (candidateIndex === previousMatchIndex + 1) {
      score += 8;
    }

    previousMatchIndex = candidateIndex;
    queryIndex += 1;

    if (queryIndex === query.length) {
      return score;
    }
  }

  return null;
}

function normalizeTutorialQuery(input) {
  const raw = String(input || "").trim().toLowerCase();
  return {
    raw,
    compact: raw.replace(/[\s_-]+/g, ""),
  };
}

async function startAuthoringSession(tutorialID, tutorialDir, flags) {
  await Promise.all([
    fs.mkdir(path.join(tutorialDir, "notes"), { recursive: true }),
    fs.mkdir(path.join(tutorialDir, "oc_sessions"), { recursive: true }),
    fs.mkdir(path.join(tutorialDir, AUDIT_DIR), { recursive: true }),
  ]);

  const phase = await detectAuthoringPhase(tutorialDir);
  if (phase === "research") {
    await startResearchSession({ tutorialID, tutorialDir, flags });
    return;
  }

  await startOutlineSession({ tutorialID, tutorialDir });

  if (!(await fileExists(path.join(tutorialDir, TUTORIAL_OUTLINE_FILE)))) {
    throw new Error(
      `Outline phase completed without creating ${TUTORIAL_OUTLINE_FILE} in ${tutorialDir}.`
    );
  }

  await startResearchSession({ tutorialID, tutorialDir, flags });
}

async function startVibeSession() {
  const exitCode = await runOpencodeSession({
    workingDir: PROJECT_DIR,
    args: [PROJECT_DIR],
    sessionLabel: "vibe",
  });

  if (exitCode !== 0) {
    throw new Error(`OpenCode vibe session exited with code ${exitCode}.`);
  }
}

async function runOpencodeSession({ workingDir, args, sessionLabel }) {
  return new Promise((resolve, reject) => {
    const child = spawn("opencode", args, {
      cwd: workingDir,
      stdio: "inherit",
    });

    child.once("error", reject);
    child.once("exit", (code, signal) => {
      if (signal) {
        reject(new Error(`OpenCode ${sessionLabel} session exited from signal ${signal}.`));
        return;
      }
      resolve(code ?? 0);
    });
  });
}

async function listTutorials() {
  try {
    const entries = await fs.readdir(TUTORIALS_DIR, { withFileTypes: true });
    const tutorialIDs = entries
      .filter((entry) => entry.isDirectory() && TUTORIAL_ID_PATTERN.test(entry.name))
      .map((entry) => entry.name)
      .sort();

    const ready = [];
    const draft = [];

    for (const tutorialID of tutorialIDs) {
      const tutorialJsonPath = path.join(TUTORIALS_DIR, tutorialID, "tutorial.json");
      try {
        const stat = await fs.stat(tutorialJsonPath);
        if (stat.isFile()) {
          ready.push(tutorialID);
          continue;
        }
      } catch (error) {
        if (error.code !== "ENOENT") {
          throw error;
        }
      }

      draft.push(tutorialID);
    }

    return { ready, draft };
  } catch (error) {
    if (error.code === "ENOENT") {
      return { ready: [], draft: [] };
    }
    throw error;
  }
}

async function buildAuthoringPrompt({ tutorialID, tutorialDir }) {
  const template = await fs.readFile(OUTLINE_INSTRUCTION_PATH, "utf8");
  return renderInstructionTemplate(template, { tutorialID, tutorialDir });
}

async function detectAuthoringPhase(tutorialDir) {
  const tutorialJsonPath = path.join(tutorialDir, TUTORIAL_JSON_FILE);
  if (await fileExists(tutorialJsonPath)) {
    return "complete";
  }

  const tutorialOutlinePath = path.join(tutorialDir, TUTORIAL_OUTLINE_FILE);
  if (await fileExists(tutorialOutlinePath)) {
    return "research";
  }

  return "outline";
}

async function startOutlineSession({ tutorialID, tutorialDir }) {
  process.stdout.write(
    `Starting outline phase. Create ${TUTORIAL_OUTLINE_FILE}, then the research phase will begin automatically.\n`
  );

  await ensureAuditDir(tutorialDir);
  const prompt = await buildAuthoringPrompt({ tutorialID, tutorialDir });
  const sessionBounds = captureSessionBounds();
  const exitCode = await runOpencodeSession({
    workingDir: tutorialDir,
    args: [
      tutorialDir,
      "--prompt",
      prompt,
      "--agent",
      AUTHORING_AGENT,
      "--model",
      AUTHORING_MODEL,
    ],
    sessionLabel: "outline",
  });

  if (exitCode !== 0) {
    throw new Error(`OpenCode outline session exited with code ${exitCode}.`);
  }

  const session = resolveSinglePhaseSession({
    tutorialDir,
    startedAt: sessionBounds.startedAt,
    endedAt: Date.now(),
    phaseLabel: "outline",
  });
  await appendAuditPhase({
    tutorialID,
    tutorialDir,
    phaseLabel: "outline",
    sessions: [session],
  });
}

async function startResearchSession({ tutorialID, tutorialDir, flags }) {
  const tutorialOutlinePath = path.join(tutorialDir, TUTORIAL_OUTLINE_FILE);
  if (!(await fileExists(tutorialOutlinePath))) {
    throw new Error(
      `Cannot start research phase because ${TUTORIAL_OUTLINE_FILE} is missing in ${tutorialDir}.`
    );
  }

  process.stdout.write(
    `Starting research phase from ${TUTORIAL_OUTLINE_FILE}. The session should research modules in parallel and produce ${TUTORIAL_JSON_FILE}.\n`
  );

  const prompt = await buildResearchPrompt({ tutorialID, tutorialDir });
  const sessionBounds = captureSessionBounds();
  const exitCode = await runOpencodeSession({
    workingDir: tutorialDir,
    args: [
      tutorialDir,
      "--prompt",
      prompt,
      "--agent",
      AUTHORING_AGENT,
      "--model",
      AUTHORING_MODEL,
    ],
    sessionLabel: "research",
  });

  if (exitCode !== 0) {
    throw new Error(`OpenCode research session exited with code ${exitCode}.`);
  }

  const rootSession = resolveSinglePhaseSession({
    tutorialDir,
    startedAt: sessionBounds.startedAt,
    endedAt: Date.now(),
    phaseLabel: "research",
  });
  const childSessions = listChildSessions(rootSession.id);
  await appendAuditPhase({
    tutorialID,
    tutorialDir,
    phaseLabel: "research",
    sessions: [rootSession, ...childSessions],
  });

  const tutorialJsonPath = path.join(tutorialDir, TUTORIAL_JSON_FILE);
  if (!(await fileExists(tutorialJsonPath))) {
    throw new Error(
      `Research phase completed without creating ${TUTORIAL_JSON_FILE} in ${tutorialDir}.`
    );
  }

  generateTutorialHtml({ tutorialDir });
  await startStudySession({ tutorialDir, flags });
}

async function buildResearchPrompt({ tutorialID, tutorialDir }) {
  const template = await fs.readFile(RESEARCH_INSTRUCTION_PATH, "utf8");
  return renderInstructionTemplate(template, { tutorialID, tutorialDir });
}

function renderInstructionTemplate(template, { tutorialID, tutorialDir }) {
  return template
    .replaceAll("{{TUTORIAL_ID}}", tutorialID)
    .replaceAll("{{TUTORIAL_DIR}}", tutorialDir)
    .replaceAll("{{ROOT_DIR}}", ROOT_DIR)
    .replaceAll("{{TUTORIAL_OUTLINE_PATH}}", path.join(tutorialDir, TUTORIAL_OUTLINE_FILE))
    .replaceAll("{{TUTORIAL_JSON_PATH}}", path.join(tutorialDir, TUTORIAL_JSON_FILE))
    .replaceAll("{{TUTORIAL_HTML_PATH}}", path.join(tutorialDir, TUTORIAL_HTML_FILE));
}

async function fileExists(filePath) {
  try {
    const stat = await fs.stat(filePath);
    return stat.isFile();
  } catch (error) {
    if (error.code === "ENOENT") {
      return false;
    }
    throw error;
  }
}

function generateTutorialHtml({ tutorialDir }) {
  const generatorPath = path.join(ROOT_DIR, "generate-tutorial-html.js");
  const result = spawnSync(process.execPath, [generatorPath, TUTORIAL_JSON_FILE, TUTORIAL_HTML_FILE], {
    cwd: tutorialDir,
    encoding: "utf8",
    stdio: "pipe",
  });

  if (result.status !== 0) {
    const errorOutput = [result.stdout, result.stderr].filter(Boolean).join("\n").trim();
    throw new Error(
      `Tutorial HTML generation failed.${errorOutput ? `\n${errorOutput}` : ""}`
    );
  }

  if (result.stdout) {
    process.stdout.write(result.stdout);
  }
}

function captureSessionBounds() {
  return {
    startedAt: Date.now(),
  };
}

async function ensureAuditDir(tutorialDir) {
  await fs.mkdir(path.join(tutorialDir, AUDIT_DIR), { recursive: true });
}

function getAuditFilePath(tutorialDir, phaseLabel) {
  const fileName = AUDIT_FILE_NAMES[phaseLabel];
  if (!fileName) {
    throw new Error(`Unsupported audit phase: ${phaseLabel}`);
  }

  return path.join(tutorialDir, AUDIT_DIR, fileName);
}

function getOpencodeDbPath() {
  const result = spawnSync("opencode", ["db", "path"], {
    cwd: ROOT_DIR,
    encoding: "utf8",
    stdio: "pipe",
  });

  if (result.status !== 0) {
    const errorOutput = [result.stdout, result.stderr].filter(Boolean).join("\n").trim();
    throw new Error(`Could not determine OpenCode DB path.${errorOutput ? `\n${errorOutput}` : ""}`);
  }

  const dbPath = (result.stdout || "").trim();
  if (!dbPath) {
    throw new Error("OpenCode DB path was empty.");
  }

  return dbPath;
}

function queryOpencodeSessions(sql) {
  const dbPath = getOpencodeDbPath();
  const result = spawnSync("sqlite3", [dbPath, "-json", sql], {
    cwd: ROOT_DIR,
    encoding: "utf8",
    stdio: "pipe",
  });

  if (result.status !== 0) {
    const errorOutput = [result.stdout, result.stderr].filter(Boolean).join("\n").trim();
    throw new Error(`Could not query OpenCode sessions.${errorOutput ? `\n${errorOutput}` : ""}`);
  }

  const raw = (result.stdout || "").trim();
  if (!raw) {
    return [];
  }

  try {
    const rows = JSON.parse(raw);
    return Array.isArray(rows) ? rows : [];
  } catch (error) {
    throw new Error(`Could not parse OpenCode session query output: ${error.message}`);
  }
}

function resolveSinglePhaseSession({ tutorialDir, startedAt, endedAt, phaseLabel }) {
  const safeDirectory = escapeSqlString(tutorialDir);
  const rows = queryOpencodeSessions(
    `select id, title, directory, path, agent, time_created, time_updated, parent_id from session ` +
    `where directory = '${safeDirectory}' and parent_id is null and time_created >= ${startedAt} and time_created <= ${endedAt} ` +
    `order by time_created asc`
  );

  if (rows.length !== 1) {
    const ids = rows.map((row) => row.id).join(", ") || "none";
    throw new Error(
      `Could not resolve exactly one OpenCode ${phaseLabel} session for ${tutorialDir}. Found: ${ids}`
    );
  }

  return normalizeSessionRow(rows[0]);
}

function listChildSessions(parentID) {
  const safeParentID = escapeSqlString(parentID);
  const rows = queryOpencodeSessions(
    `select id, title, directory, path, agent, time_created, time_updated, parent_id from session ` +
    `where parent_id = '${safeParentID}' order by time_created asc`
  );

  return rows.map(normalizeSessionRow);
}

function normalizeSessionRow(row) {
  return {
    id: typeof row?.id === "string" ? row.id : "",
    title: typeof row?.title === "string" ? row.title : "",
    directory: typeof row?.directory === "string" ? row.directory : "",
    path: typeof row?.path === "string" ? row.path : "",
    agent: typeof row?.agent === "string" ? row.agent : "",
    parentID: typeof row?.parent_id === "string" ? row.parent_id : "",
    timeCreated: Number.isFinite(row?.time_created) ? row.time_created : 0,
    timeUpdated: Number.isFinite(row?.time_updated) ? row.time_updated : 0,
  };
}

function escapeSqlString(value) {
  return String(value).replaceAll("'", "''");
}

function exportOpencodeSession(sessionID) {
  const result = spawnSync("opencode", ["export", sessionID], {
    cwd: ROOT_DIR,
    encoding: "utf8",
    stdio: "pipe",
    maxBuffer: 20 * 1024 * 1024,
  });

  if (result.status !== 0) {
    const errorOutput = [result.stdout, result.stderr].filter(Boolean).join("\n").trim();
    throw new Error(`Could not export OpenCode session ${sessionID}.${errorOutput ? `\n${errorOutput}` : ""}`);
  }

  return (result.stdout || "").trim();
}

async function appendAuditPhase({ tutorialID, tutorialDir, phaseLabel, sessions }) {
  await ensureAuditDir(tutorialDir);
  const auditFilePath = getAuditFilePath(tutorialDir, phaseLabel);
  const exportedAt = new Date().toISOString();
  const blocks = [
    `=== ${phaseLabel.toUpperCase()} AUDIT ===`,
    `tutorial: ${tutorialID}`,
    `directory: ${tutorialDir}`,
    `exportedAt: ${exportedAt}`,
    `sessionCount: ${sessions.length}`,
    "",
  ];

  for (const session of sessions) {
    const exportText = exportOpencodeSession(session.id);
    blocks.push(`--- session ${session.id} ---`);
    blocks.push(`title: ${session.title || "(untitled)"}`);
    blocks.push(`agent: ${session.agent || ""}`);
    blocks.push(`parentID: ${session.parentID || ""}`);
    blocks.push(`timeCreated: ${session.timeCreated}`);
    blocks.push(`timeUpdated: ${session.timeUpdated}`);
    blocks.push("");
    blocks.push(exportText);
    blocks.push("");
  }

  await fs.writeFile(auditFilePath, `${blocks.join("\n")}\n`, "utf8");
}

async function startStudySession({ tutorialDir, flags }) {
  await runTutorialApp({
    rootDir: ROOT_DIR,
    tutorialDir,
    tutorialJsonPath: path.join(tutorialDir, TUTORIAL_JSON_FILE),
    tutorialHtmlPath: path.join(tutorialDir, TUTORIAL_HTML_FILE),
    notesDir: path.join(tutorialDir, "notes"),
    ocSessionsDir: path.join(tutorialDir, "oc_sessions"),
    shouldOpenBrowser: !flags.has("--no-browser"),
  });
}

function printUsage() {
  process.stdout.write(
      "Usage:\n" +
      "  tutor [--no-browser]\n" +
      "  tutor vibe\n"
  );
}

main().catch((error) => {
  process.stderr.write(`${error.message}\n`);
  process.exit(1);
});
