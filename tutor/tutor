#!/usr/bin/env node

const fs = require("node:fs/promises");
const path = require("node:path");
const readline = require("node:readline/promises");
const { spawn, spawnSync } = require("node:child_process");
const { runTutorialApp } = require("./tutor-runtime");

const ROOT_DIR = __dirname;
const PROJECT_DIR = ROOT_DIR;
const TUTORIALS_DIR = path.join(ROOT_DIR, "tutorials");
const OUTLINE_INSTRUCTION_PATH = path.join(ROOT_DIR, "tutorial_outline_instruction.md");
const RESEARCH_INSTRUCTION_PATH = path.join(ROOT_DIR, "tutorial_research_instruction.md");
const TUTORIAL_ID_PATTERN = /^[a-z0-9][a-z0-9_-]*$/;
const TUTORIAL_OUTLINE_FILE = "tutorial-outline.json";
const TUTORIAL_JSON_FILE = "tutorial.json";
const TUTORIAL_HTML_FILE = "tutorial.html";

async function main() {
  const args = process.argv.slice(2);
  const flags = new Set(args.filter((arg) => arg.startsWith("-")));
  const positionals = args.filter((arg) => !arg.startsWith("-"));

  if (flags.has("--help") || flags.has("-h")) {
    printUsage();
    return;
  }

  if (positionals[0] === "vibe") {
    if (positionals.length > 1) {
      throw new Error("Run `tutor vibe` with no additional positional arguments.");
    }

    await startVibeSession();
    return;
  }

  if (positionals.length > 0) {
    throw new Error("Run `tutor` with no positional arguments, or use `tutor vibe`.");
  }

  const selection = await promptForTutorialID();
  if (!selection) {
    return;
  }

  const tutorialDir = path.join(TUTORIALS_DIR, selection.id);
  if (selection.mode === "study") {
    await startStudySession({ tutorialDir, flags });
    return;
  }

  await startAuthoringSession(selection.id, tutorialDir, flags);
}

async function promptForTutorialID() {
  await fs.mkdir(TUTORIALS_DIR, { recursive: true });
  const tutorials = await listTutorials();

  process.stdout.write("Available tutorials:\n");
  if (tutorials.ready.length === 0) {
    process.stdout.write("  (none yet)\n");
  } else {
    for (const tutorialID of tutorials.ready) {
      process.stdout.write(`  - ${tutorialID}\n`);
    }
  }

  if (tutorials.draft.length > 0) {
    process.stdout.write("\nDraft tutorials:\n");
    for (const tutorialID of tutorials.draft) {
      process.stdout.write(`  - ${tutorialID}\n`);
    }
  }

  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  });

  try {
    const answer = (await rl.question("\nTutorial id: ")).trim();
    if (!answer) {
      process.stdout.write("No tutorial selected.\n");
      return null;
    }

    if (!TUTORIAL_ID_PATTERN.test(answer)) {
      throw new Error("Tutorial IDs must use lowercase letters, numbers, underscores, or hyphens.");
    }

    if (tutorials.ready.includes(answer)) {
      return { mode: "study", id: answer };
    }

    if (tutorials.draft.includes(answer)) {
      const shouldContinue = await confirm(
        rl,
        `Tutorial \"${answer}\" is a draft without a finished tutorial.json. Continue authoring it?`,
        true
      );
      return shouldContinue ? { mode: "author", id: answer } : null;
    }

    const shouldCreate = await confirm(
      rl,
      `Tutorial \"${answer}\" does not exist. Create it?`,
      true
    );
    return shouldCreate ? { mode: "author", id: answer } : null;
  } finally {
    rl.close();
  }
}

async function confirm(rl, message, defaultYes) {
  const suffix = defaultYes ? " [Y/n] " : " [y/N] ";
  const answer = (await rl.question(`${message}${suffix}`)).trim().toLowerCase();

  if (answer === "") {
    return defaultYes;
  }

  if (answer === "y" || answer === "yes") {
    return true;
  }

  if (answer === "n" || answer === "no") {
    return false;
  }

  process.stdout.write("Please answer yes or no.\n");
  return confirm(rl, message, defaultYes);
}

async function startAuthoringSession(tutorialID, tutorialDir, flags) {
  await fs.mkdir(path.join(tutorialDir, "notes"), { recursive: true });

  const phase = await detectAuthoringPhase(tutorialDir);
  if (phase === "research") {
    await startResearchSession({ tutorialID, tutorialDir, flags });
    return;
  }

  await startOutlineSession({ tutorialID, tutorialDir });

  if (!(await fileExists(path.join(tutorialDir, TUTORIAL_OUTLINE_FILE)))) {
    throw new Error(
      `Outline phase completed without creating ${TUTORIAL_OUTLINE_FILE} in ${tutorialDir}.`
    );
  }

  await startResearchSession({ tutorialID, tutorialDir, flags });
}

async function startVibeSession() {
  const exitCode = await runOpencodeSession({
    workingDir: PROJECT_DIR,
    args: [PROJECT_DIR],
    sessionLabel: "vibe",
  });

  if (exitCode !== 0) {
    throw new Error(`OpenCode vibe session exited with code ${exitCode}.`);
  }
}

async function runOpencodeSession({ workingDir, args, sessionLabel }) {
  return new Promise((resolve, reject) => {
    const child = spawn("opencode", args, {
      cwd: workingDir,
      stdio: "inherit",
    });

    child.once("error", reject);
    child.once("exit", (code, signal) => {
      if (signal) {
        reject(new Error(`OpenCode ${sessionLabel} session exited from signal ${signal}.`));
        return;
      }
      resolve(code ?? 0);
    });
  });
}

async function listTutorials() {
  try {
    const entries = await fs.readdir(TUTORIALS_DIR, { withFileTypes: true });
    const tutorialIDs = entries
      .filter((entry) => entry.isDirectory() && TUTORIAL_ID_PATTERN.test(entry.name))
      .map((entry) => entry.name)
      .sort();

    const ready = [];
    const draft = [];

    for (const tutorialID of tutorialIDs) {
      const tutorialJsonPath = path.join(TUTORIALS_DIR, tutorialID, "tutorial.json");
      try {
        const stat = await fs.stat(tutorialJsonPath);
        if (stat.isFile()) {
          ready.push(tutorialID);
          continue;
        }
      } catch (error) {
        if (error.code !== "ENOENT") {
          throw error;
        }
      }

      draft.push(tutorialID);
    }

    return { ready, draft };
  } catch (error) {
    if (error.code === "ENOENT") {
      return { ready: [], draft: [] };
    }
    throw error;
  }
}

async function buildAuthoringPrompt({ tutorialID, tutorialDir }) {
  const template = await fs.readFile(OUTLINE_INSTRUCTION_PATH, "utf8");
  return renderInstructionTemplate(template, { tutorialID, tutorialDir });
}

async function detectAuthoringPhase(tutorialDir) {
  const tutorialJsonPath = path.join(tutorialDir, TUTORIAL_JSON_FILE);
  if (await fileExists(tutorialJsonPath)) {
    return "complete";
  }

  const tutorialOutlinePath = path.join(tutorialDir, TUTORIAL_OUTLINE_FILE);
  if (await fileExists(tutorialOutlinePath)) {
    return "research";
  }

  return "outline";
}

async function startOutlineSession({ tutorialID, tutorialDir }) {
  process.stdout.write(
    `Starting outline phase. Create ${TUTORIAL_OUTLINE_FILE}, then the research phase will begin automatically.\n`
  );

  const prompt = await buildAuthoringPrompt({ tutorialID, tutorialDir });
  const exitCode = await runOpencodeSession({
    workingDir: tutorialDir,
    args: [tutorialDir, "--prompt", prompt],
    sessionLabel: "outline",
  });

  if (exitCode !== 0) {
    throw new Error(`OpenCode outline session exited with code ${exitCode}.`);
  }
}

async function startResearchSession({ tutorialID, tutorialDir, flags }) {
  const tutorialOutlinePath = path.join(tutorialDir, TUTORIAL_OUTLINE_FILE);
  if (!(await fileExists(tutorialOutlinePath))) {
    throw new Error(
      `Cannot start research phase because ${TUTORIAL_OUTLINE_FILE} is missing in ${tutorialDir}.`
    );
  }

  process.stdout.write(
    `Starting research phase from ${TUTORIAL_OUTLINE_FILE}. The session should research modules in parallel and produce ${TUTORIAL_JSON_FILE}.\n`
  );

  const prompt = await buildResearchPrompt({ tutorialID, tutorialDir });
  const exitCode = await runOpencodeSession({
    workingDir: tutorialDir,
    args: [tutorialDir, "--prompt", prompt],
    sessionLabel: "research",
  });

  if (exitCode !== 0) {
    throw new Error(`OpenCode research session exited with code ${exitCode}.`);
  }

  const tutorialJsonPath = path.join(tutorialDir, TUTORIAL_JSON_FILE);
  if (!(await fileExists(tutorialJsonPath))) {
    throw new Error(
      `Research phase completed without creating ${TUTORIAL_JSON_FILE} in ${tutorialDir}.`
    );
  }

  generateTutorialHtml({ tutorialDir });
  await startStudySession({ tutorialDir, flags });
}

async function buildResearchPrompt({ tutorialID, tutorialDir }) {
  const template = await fs.readFile(RESEARCH_INSTRUCTION_PATH, "utf8");
  return renderInstructionTemplate(template, { tutorialID, tutorialDir });
}

function renderInstructionTemplate(template, { tutorialID, tutorialDir }) {
  return template
    .replaceAll("{{TUTORIAL_ID}}", tutorialID)
    .replaceAll("{{TUTORIAL_DIR}}", tutorialDir)
    .replaceAll("{{ROOT_DIR}}", ROOT_DIR)
    .replaceAll("{{TUTORIAL_OUTLINE_PATH}}", path.join(tutorialDir, TUTORIAL_OUTLINE_FILE))
    .replaceAll("{{TUTORIAL_JSON_PATH}}", path.join(tutorialDir, TUTORIAL_JSON_FILE))
    .replaceAll("{{TUTORIAL_HTML_PATH}}", path.join(tutorialDir, TUTORIAL_HTML_FILE));
}

async function fileExists(filePath) {
  try {
    const stat = await fs.stat(filePath);
    return stat.isFile();
  } catch (error) {
    if (error.code === "ENOENT") {
      return false;
    }
    throw error;
  }
}

function generateTutorialHtml({ tutorialDir }) {
  const generatorPath = path.join(ROOT_DIR, "generate-tutorial-html.js");
  const result = spawnSync(process.execPath, [generatorPath, TUTORIAL_JSON_FILE, TUTORIAL_HTML_FILE], {
    cwd: tutorialDir,
    encoding: "utf8",
    stdio: "pipe",
  });

  if (result.status !== 0) {
    const errorOutput = [result.stdout, result.stderr].filter(Boolean).join("\n").trim();
    throw new Error(
      `Tutorial HTML generation failed.${errorOutput ? `\n${errorOutput}` : ""}`
    );
  }

  if (result.stdout) {
    process.stdout.write(result.stdout);
  }
}

async function startStudySession({ tutorialDir, flags }) {
  await runTutorialApp({
    rootDir: ROOT_DIR,
    tutorialDir,
    tutorialJsonPath: path.join(tutorialDir, TUTORIAL_JSON_FILE),
    tutorialHtmlPath: path.join(tutorialDir, TUTORIAL_HTML_FILE),
    notesDir: path.join(tutorialDir, "notes"),
    shouldOpenBrowser: !flags.has("--no-browser"),
    shouldAttachTui: !flags.has("--no-attach"),
  });
}

function printUsage() {
  process.stdout.write(
    "Usage:\n" +
      "  tutor [--no-browser] [--no-attach]\n" +
      "  tutor vibe\n"
  );
}

main().catch((error) => {
  process.stderr.write(`${error.message}\n`);
  process.exit(1);
});
